{
  "name": "linguasub",
  "version": "1.0.0",
  "type": "module",
  "description": "Industry-grade subtitle generation, translation, and video burning application",
  "author": {
    "name": "Urgen Dorjee",
    "email": ""
  },
  "copyright": "Copyright (c) 2026 Urgen Dorjee. All rights reserved.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:frontend": "vite build",
    "build:backend": "node scripts/build-backend.js",
    "build:dist": "electron-builder",
    "build": "npm run build:backend && npm run build:frontend && npm run build:dist",
    "preview": "vite preview",
    "setup:python": "node scripts/setup-python.js",
    "setup:ffmpeg": "node scripts/download-ffmpeg.js",
    "setup:all": "npm run setup:python && npm run setup:ffmpeg",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-virtual": "^3.11.2",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.12.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-resizable-panels": "^4.7.1",
    "react-router-dom": "^7.1.0",
    "video.js": "^8.18.1",
    "wavesurfer.js": "^7.8.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.urgendorjee.linguasub",
    "productName": "LinguaSub",
    "copyright": "Copyright (c) 2026 Urgen Dorjee. All rights reserved.",
    "directories": {
      "buildResources": "build",
      "output": "C:/temp/LinguaSub-release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      },
      {
        "from": "C:/temp/sf-backend-build/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "shortcutName": "LinguaSub"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-portable.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "urgendorjee",
        "repo": "LinguaSub"
      }
    ]
  }
}
